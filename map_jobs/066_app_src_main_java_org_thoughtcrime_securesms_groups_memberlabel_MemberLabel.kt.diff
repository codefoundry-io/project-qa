+    @JvmStatic
+    fun sanitizeLabelText(text: String): String {
+      val collapsed = StringUtil.trimToVisualBounds(text.replace(Regex("\\s+"), " "))
+      return truncateLabelText(collapsed)
+    }
+
+    /**
